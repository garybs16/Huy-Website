{
  "name": "aci-rough-mirror",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c yellow,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "nodemon server/index.js",
    "start": "node server/index.js",
    "check:harmony": "node scripts/harmony-check.mjs",
    "check:production": "node scripts/production-smoke.mjs",
    "check:readiness": "node scripts/readiness-check.mjs",
    "admin:hash": "node scripts/hash-admin-password.mjs",
    "verify": "npm run build && npm audit && npm run check:readiness && npm run check:harmony && npm run check:production",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.0",
    "stripe": "^22.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.11",
    "vite": "^8.0.10"
  }
}
