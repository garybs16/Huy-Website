{
  "name": "aci-rough-mirror",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c yellow,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "nodemon server/index.js",
    "start": "node server/index.js",
    "test": "node --test",
    "check:harmony": "node scripts/harmony-check.mjs",
    "check:production": "node scripts/production-smoke.mjs",
    "check:content": "node scripts/content-regression.mjs",
    "check:readiness": "node scripts/readiness-check.mjs",
    "check:health": "node scripts/healthcheck.mjs",
    "admin:hash": "node scripts/hash-admin-password.mjs",
    "admin:mfa-setup": "node scripts/generate-admin-mfa.mjs",
    "backup:encrypted": "node scripts/encrypted-database-backup.mjs",
    "env:production": "node scripts/generate-production-env.mjs",
    "verify": "npm run build && npm audit && npm test && npm run check:content && npm run check:readiness && npm run check:harmony && npm run check:production",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.4.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "morgan": "^1.11.0",
    "otpauth": "9.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.0",
    "stripe": "^22.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@emnapi/core": "1.11.2",
    "@emnapi/runtime": "1.11.2",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "9.2.4",
    "nodemon": "^3.1.11",
    "vite": "^8.0.10"
  }
}
