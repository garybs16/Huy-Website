# Copy these values into your AWS service environment variables.
# Do not commit a filled production env file.

NODE_ENV=production
PORT=4000
SERVE_STATIC_APP=true
TRUST_PROXY=true
STATIC_DIR=dist

# Use persistent storage for these paths.
DATA_DIR=/var/data
DATABASE_URL=/var/data/enrollment.db

# Same-origin AWS deploy usually does not need CORS_ORIGINS.
CORS_ORIGINS=
PUBLIC_APP_URL=https://your-domain.com

# Admin auth. Prefer ADMIN_PASSWORD_HASH over ADMIN_PASSWORD in production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace-with-generated-hash
ADMIN_SESSION_SECRET=replace-with-generated-secret
ADMIN_SESSION_COOKIE_SAME_SITE=lax
ADMIN_SESSION_TTL_HOURS=12
API_ADMIN_KEY=replace-with-generated-api-key

# Stripe. Leave empty only if you are intentionally using manual payment mode.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# Optional admissions notifications.
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_SECRET=replace-with-generated-secret
